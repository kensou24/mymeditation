<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFile"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/item_corner_radius"
    app:cardElevation="@dimen/item_elevation"
    app:cardUseCompatPadding="true"
    android:clickable="true"
    android:focusable="true"
    android:checkable="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Now-playing indicator -->
        <View
            android:id="@+id/viewNowPlayingIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="24dp"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <!-- Circular icon container -->
        <ImageView
            android:id="@+id/imageViewIconBg"
            android:layout_width="@dimen/item_icon_size"
            android:layout_height="@dimen/item_icon_size"
            android:background="@drawable/item_icon_bg_circle"
            android:scaleType="center"
            android:src="@drawable/ic_music_note"
            android:importantForAccessibility="no"
            android:padding="@dimen/spacing_sm" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_sm">

            <TextView
                android:id="@+id/textViewFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                android:textColor="@color/text_primary"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/textViewFileSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:letterSpacing="0.04"
                android:textColor="@color/text_secondary"
                android:paddingTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
