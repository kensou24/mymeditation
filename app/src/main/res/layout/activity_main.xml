<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/buttonSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="0dp"
            android:text=""
            android:textSize="0sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 滚动内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 目录列表标题 -->
            <TextView
                android:id="@+id/textViewDirectoryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_directory"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:paddingBottom="8dp"
                android:paddingTop="4dp" />

            <!-- 加载进度条 -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewDirectories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- 文件列表标题 + 排序按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/textViewFileTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/buttonSort"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/sort_by_name"
                    android:textSize="13sp"
                    android:textColor="@color/text_white"
                    android:background="@drawable/button_icon_primary"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:visibility="gone"
                    android:elevation="2dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 播放控制区域 -->
    <LinearLayout
        android:id="@+id/playerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/player_background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <!-- 状态文字 -->
        <TextView
            android:id="@+id/textViewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stopped"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.6"
            android:paddingBottom="4dp" />

        <!-- 当前文件名 -->
        <TextView
            android:id="@+id/textViewCurrentFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/textViewCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:minWidth="36dp"
                android:alpha="0.7" />

            <SeekBar
                android:id="@+id/seekBarProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textViewTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:minWidth="36dp"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- 主播放控件: 上一首 | 播放/暂停 | 下一首 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/buttonPrevious"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:text="@string/previous"
                android:textColor="@color/text_white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_previous"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp"
                android:includeFontPadding="false" />

            <Button
                android:id="@+id/buttonPlay"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="3"
                android:text="@string/play"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_icon_accent"
                android:drawableStart="@drawable/ic_play"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:elevation="4dp"
                android:includeFontPadding="false" />

            <Button
                android:id="@+id/buttonPause"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="3"
                android:text="@string/pause"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_pause"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:elevation="4dp"
                android:includeFontPadding="false"
                android:visibility="gone" />

            <Button
                android:id="@+id/buttonNext"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:text="@string/next"
                android:textColor="@color/text_white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_next"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginStart="6dp"
                android:elevation="2dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 次级控件: 播放模式 | 定时器 | 停止 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/buttonPlayMode"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/mode_sequence"
                android:textColor="@color/text_white"
                android:textSize="11sp"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_repeat"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp"
                android:includeFontPadding="false" />

            <Button
                android:id="@+id/buttonSetTimer"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/timer_hint"
                android:textColor="@color/text_white"
                android:textSize="11sp"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_timer"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp"
                android:includeFontPadding="false" />

            <Button
                android:id="@+id/buttonStop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/stop"
                android:textColor="@color/text_white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_icon_primary"
                android:drawableStart="@drawable/ic_stop"
                android:drawablePadding="1dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:layout_marginStart="6dp"
                android:elevation="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingTop="6dp"
            android:gravity="center"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
