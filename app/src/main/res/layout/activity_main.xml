<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="@string/app_title"
        app:titleTextColor="@color/text_white"
        app:titleTextAppearance="@style/TextAppearance.MyMeditation.Title"
        app:subtitleTextColor="@color/text_white">

        <ImageButton
            android:id="@+id/buttonSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/theme_dialog_title"
            android:padding="12dp"
            app:tint="@color/text_white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Scrollable Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Directory section title -->
            <TextView
                android:id="@+id/textViewDirectoryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_directory"
                android:textAppearance="@style/TextAppearance.MyMeditation.SectionTitle"
                android:textColor="@color/text_primary"
                android:paddingBottom="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_xs" />

            <!-- Loading progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewDirectories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <!-- A7: Empty state (shown when no directories / files found) -->
            <LinearLayout
                android:id="@+id/emptyStateView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="@dimen/spacing_xxl"
                android:paddingBottom="@dimen/spacing_xxl"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageViewEmptyIcon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_folder"
                    android:alpha="0.35"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/textViewEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/empty_state_title"
                    android:textAppearance="@style/TextAppearance.MyMeditation.SectionTitle"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/textViewEmptyMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:gravity="center"
                    android:text="@string/empty_state_message"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:paddingStart="@dimen/spacing_xl"
                    android:paddingEnd="@dimen/spacing_xl" />
            </LinearLayout>

            <!-- File section title + sort button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/textViewFileTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:textAppearance="@style/TextAppearance.MyMeditation.SectionTitle"
                    android:textColor="@color/text_primary"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSort"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/sort_by_name"
                    android:textSize="13sp"
                    android:textColor="@color/text_white"
                    android:visibility="gone"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    app:cornerRadius="18dp"
                    app:backgroundTint="@color/primary_light" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Player Control Bar -->
    <LinearLayout
        android:id="@+id/playerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/player_background"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_lg"
        android:elevation="8dp">

        <!-- Status + filename row -->
        <TextView
            android:id="@+id/textViewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stopped"
            android:textColor="@color/text_white"
            android:textAppearance="@style/TextAppearance.MyMeditation.PlayerCaption"
            android:alpha="0.7"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/textViewCurrentFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_white"
            android:textAppearance="@style/TextAppearance.MyMeditation.PlayerTitle"
            android:paddingBottom="@dimen/spacing_md"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Seekbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="@dimen/spacing_lg">

            <TextView
                android:id="@+id/textViewCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="40dp"
                android:alpha="0.7" />

            <SeekBar
                android:id="@+id/seekBarProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/seekbar_track"
                android:thumb="@drawable/seekbar_thumb"
                android:splitTrack="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/textViewTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="40dp"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- Main transport controls: Previous | Play/Pause | Next -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="@dimen/spacing_md">

            <ImageButton
                android:id="@+id/buttonPrevious"
                android:layout_width="@dimen/player_button_secondary"
                android:layout_height="@dimen/player_button_secondary"
                android:src="@drawable/ic_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/text_white" />

            <!-- Single Play/Pause toggle button -->
            <ImageButton
                android:id="@+id/buttonPlayPause"
                android:layout_width="@dimen/player_button_primary"
                android:layout_height="@dimen/player_button_primary"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_play"
                android:background="@drawable/play_button_circle"
                android:contentDescription="@string/play"
                android:padding="@dimen/spacing_md"
                android:elevation="4dp"
                app:tint="@color/text_white" />

            <ImageButton
                android:id="@+id/buttonNext"
                android:layout_width="@dimen/player_button_secondary"
                android:layout_height="@dimen/player_button_secondary"
                android:src="@drawable/ic_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/text_white" />

        </LinearLayout>

        <!-- Secondary controls: PlayMode | Timer | Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/buttonPlayMode"
                android:layout_width="0dp"
                android:layout_height="@dimen/player_button_compact"
                android:layout_weight="1"
                android:src="@drawable/ic_repeat"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/mode_sequence"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/text_white"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/buttonSetTimer"
                android:layout_width="0dp"
                android:layout_height="@dimen/player_button_compact"
                android:layout_weight="1"
                android:src="@drawable/ic_timer"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/timer_hint"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/text_white"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/buttonStop"
                android:layout_width="0dp"
                android:layout_height="@dimen/player_button_compact"
                android:layout_weight="1"
                android:src="@drawable/ic_stop"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/stop"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/text_white"
                android:alpha="0.7" />

        </LinearLayout>

        <!-- Timer countdown -->
        <TextView
            android:id="@+id/textViewTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/accent"
            android:textAppearance="@style/TextAppearance.MyMeditation.Timer"
            android:paddingTop="@dimen/spacing_sm"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
